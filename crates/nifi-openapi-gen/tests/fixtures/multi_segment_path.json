{
  "openapi": "3.0.1",
  "paths": {
    "/policies/{action}/{resource}": {
      "get": {
        "operationId": "getAccessPolicyForResource",
        "summary": "Gets an access policy for the specified action and resource",
        "tags": ["Policies"],
        "parameters": [
          { "in": "path", "name": "action", "required": true, "schema": { "type": "string" } },
          { "in": "path", "name": "resource", "required": true, "schema": { "type": "string", "pattern": ".+" } }
        ],
        "security": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccessPolicyEntity" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessPolicyDTO": {
        "type": "object",
        "properties": { "resource": { "type": "string" }, "action": { "type": "string" } }
      },
      "AccessPolicyEntity": {
        "type": "object",
        "properties": { "component": { "$ref": "#/components/schemas/AccessPolicyDTO" } }
      }
    }
  }
}
